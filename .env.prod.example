# =============================================================================
# SesameFS — Production Environment
# =============================================================================
# Usage:
#   cp .env.prod.example .env
#   nano .env    ← fill in every <...> value
#
# Then deploy:
#   docker compose -f docker-compose.prod.yml up -d --build
#
# See docs/DEPLOY.md for the full step-by-step guide.
# NEVER commit .env with real credentials.
# =============================================================================


# =============================================================================
# Domains
# =============================================================================

# Main app — no https://, no trailing slash
DOMAIN=<e.g. files.sesamedisk.com>

# OnlyOffice — must be a separate subdomain on the same server
OFFICE_DOMAIN=<e.g. office.sesamedisk.com>


# =============================================================================
# AWS S3
# =============================================================================

AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
S3_BUCKET=<your-bucket-name>
S3_REGION=us-east-1

# Leave empty for real AWS S3.
# Set for S3-compatible APIs (Cloudflare R2, Backblaze B2, etc.)
S3_ENDPOINT=


# =============================================================================
# Cassandra
# =============================================================================

CASSANDRA_CLUSTER_NAME=sesamefs-prod
CASSANDRA_MAX_HEAP_SIZE=2G
CASSANDRA_HEAP_NEWSIZE=400M

# Credentials — only if Cassandra auth is enabled
# CASSANDRA_USERNAME=cassandra
# CASSANDRA_PASSWORD=<strong-password>


# =============================================================================
# Multi-Region (optional)
# =============================================================================
# Leave these commented out for single-region deployments.
# For multi-region, uncomment and fill in per-server values.
# See docs/DEPLOY.md § Multi-Region for the full guide.
# =============================================================================

# Region identifier for this server (e.g. usa, eu, asia)
# SERVER_REGION=usa

# Cassandra hosts — comma-separated, local node first
# Single-region default: cassandra:9042 (Docker hostname)
# Multi-region: use private IPs of all Cassandra nodes
# CASSANDRA_HOSTS=10.0.1.10:9042,10.0.2.20:9042,10.0.3.30:9042

# Cassandra datacenter and rack for this node
# CASSANDRA_DC=dc-usa
# CASSANDRA_LOCAL_DC=dc-usa
# CASSANDRA_RACK=rack1

# Cassandra seed nodes — private IPs, comma-separated (2 seeds per DC recommended)
# CASSANDRA_SEEDS=10.0.1.10,10.0.2.20,10.0.3.30

# Private/vRack IP of THIS server — used for Cassandra inter-node communication
# CASSANDRA_BIND_IP=10.0.1.10
# CASSANDRA_LISTEN_ADDRESS=10.0.1.10
# CASSANDRA_BROADCAST_ADDRESS=10.0.1.10
# CASSANDRA_RPC_ADDRESS=0.0.0.0
# CASSANDRA_BROADCAST_RPC_ADDRESS=10.0.1.10


# =============================================================================
# First superadmin
# =============================================================================
# Email of the initial superadmin. On first startup, SesameFS seeds the DB with
# a superadmin account in the platform org using this email. When you log in via
# OIDC with this address, you enter as superadmin and can manage organizations.
# After the first deploy this value is ignored (seed only runs once).
FIRST_SUPERADMIN_EMAIL=<your-email@yourdomain.com>

# =============================================================================
# OIDC (accounts.sesamedisk.com)
# =============================================================================
# Register a client with redirect URI: https://<DOMAIN>/sso
# docker-compose.prod.yml sets OIDC_REDIRECT_URIS automatically from ${DOMAIN}

OIDC_ISSUER=<your-oidc-issuer-url, e.g. https://auth.example.com/openid>
OIDC_CLIENT_ID=<your-oidc-client-id>
OIDC_CLIENT_SECRET=<your-oidc-client-secret>

# Session signing key — generate with: openssl rand -hex 32
# NEVER change after deploy (invalidates all active sessions)
OIDC_JWT_SIGNING_KEY=<run: openssl rand -hex 32>


# =============================================================================
# OnlyOffice
# =============================================================================

# Shared JWT secret — generate with: openssl rand -hex 32
ONLYOFFICE_JWT_SECRET=<run: openssl rand -hex 32>
