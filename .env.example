# SesameFS Environment Variables
# Copy this file to .env and customize for your environment

# Server
PORT=8080

# Database (Cassandra)
CASSANDRA_HOSTS=localhost:9042
CASSANDRA_KEYSPACE=sesamefs
CASSANDRA_LOCAL_DC=datacenter1
# CASSANDRA_USERNAME=cassandra
# CASSANDRA_PASSWORD=cassandra

# Storage (AWS/S3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=sesamefs-blocks
# S3_ENDPOINT=http://localhost:9000    # For MinIO

# Authentication
AUTH_DEV_MODE=true
OIDC_ISSUER=https://accounts.sesamedisk.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Optional: Config file path
# CONFIG_PATH=config.yaml

  OIDC_ENABLED=true
  OIDC_ISSUER=https://t-accounts.sesamedisk.com/
  OIDC_CLIENT_ID=657640
  OIDC_CLIENT_SECRET=<client-secret>
  OIDC_REDIRECT_URIS=http://localhost:3000/sso
  OIDC_SESSION_TTL=24h
  OIDC_JWT_SIGNING_KEY=your-secret-key  # Optional, for JWT sessions
  OIDC_AUTO_PROVISION=true  # Create users on first login
