# =============================================================================
# SesameFS Environment Variables
# =============================================================================
# Copy this file to .env and customize for your environment:
#   cp .env.example .env
#
# IMPORTANT: .env is in .gitignore — NEVER commit it with real credentials.
# =============================================================================

# =============================================================================
# Host Port Mappings (exposed on your machine)
# =============================================================================
SESAMEFS_HOST_PORT=8082
CASSANDRA_HOST_PORT=9042
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
ONLYOFFICE_HOST_PORT=8088
FRONTEND_HOST_PORT=3000

# =============================================================================
# SesameFS API Server
# =============================================================================
# Internal port inside the container (usually no need to change)
PORT=8080

# Public URL where the API is accessible (used for generating download/upload links)
SERVER_URL=http://localhost:8082

# =============================================================================
# Authentication
# =============================================================================
# Dev mode: uses static dev tokens instead of OIDC (see docs/TESTING.md)
AUTH_DEV_MODE=true

# Allow unauthenticated requests to fall back to dev identity (dev only!)
AUTH_ALLOW_ANONYMOUS=true

# =============================================================================
# OIDC Authentication (Production)
# =============================================================================
# OIDC_ENABLED=false
# OIDC_ISSUER=https://t-accounts.sesamedisk.com/
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URIS=http://localhost:3000/sso
# OIDC_SESSION_TTL=24h
# OIDC_JWT_SIGNING_KEY=change-me-to-a-random-string
# OIDC_AUTO_PROVISION=true

# =============================================================================
# Cassandra Database
# =============================================================================
CASSANDRA_HOSTS=cassandra:9042
CASSANDRA_KEYSPACE=sesamefs
CASSANDRA_LOCAL_DC=datacenter1
CASSANDRA_CLUSTER_NAME=sesamefs
CASSANDRA_DC=datacenter1
CASSANDRA_MAX_HEAP_SIZE=512M
CASSANDRA_HEAP_NEWSIZE=100M
# CASSANDRA_USERNAME=cassandra
# CASSANDRA_PASSWORD=cassandra

# =============================================================================
# S3 / MinIO Storage
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=sesamefs-blocks
S3_ENDPOINT=http://minio:9000

# MinIO root credentials (must match AWS_ACCESS_KEY_ID/SECRET for local dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# =============================================================================
# OnlyOffice Document Server
# =============================================================================
# IMPORTANT: Change this in production!
ONLYOFFICE_JWT_SECRET=change-me-to-a-random-string

# =============================================================================
# Seafile CLI — Sync Protocol Testing
# =============================================================================
# These are used by the seafile-cli container to test the sync protocol
# against the local SesameFS server.
SEAF_CLI_SERVER_URL=http://sesamefs:8080
SEAF_CLI_USERNAME=00000000-0000-0000-0000-000000000001
SEAF_CLI_PASSWORD=dev-token-123

# =============================================================================
# Seafile CLI Debug — Protocol Reverse Engineering
# =============================================================================
# Points to a REAL Seafile server for protocol capture with mitmproxy.
# Fill in YOUR credentials here. NEVER commit real values.
# SEAF_DEBUG_SERVER_URL=https://your-seafile-server.com
# SEAF_DEBUG_USERNAME=your-email@example.com
# SEAF_DEBUG_PASSWORD=your-password

# =============================================================================
# File Preview Limits
# =============================================================================
# Maximum file sizes for inline preview in browser
# These limits protect against memory exhaustion and browser freezing
# Values are in bytes (can also be set in config.yaml)

# General files (images, PDFs, etc.)
# FILEVIEW_MAX_PREVIEW_BYTES=1073741824       # 1 GB

# Videos (4K recordings, long videos)
# FILEVIEW_MAX_VIDEO_BYTES=10737418240        # 10 GB

# Text files (prevent browser freeze on huge logs)
# FILEVIEW_MAX_TEXT_BYTES=52428800            # 50 MB

# Extracted iWork previews (Pages, Numbers, Keynote)
# FILEVIEW_MAX_IWORK_PREVIEW_BYTES=52428800   # 50 MB

# =============================================================================
# Frontend
# =============================================================================
# Backend API URL for the frontend build.
# Empty = relative URLs via nginx proxy (recommended for Docker).
# Set explicitly only if frontend and backend are on different hosts.
SESAMEFS_API_URL=
