# =============================================================================
# SesameFS — Development Environment
# =============================================================================
# Usage:
#   cp .env.example .env
#   docker compose up --build
#
# All defaults work out of the box — no changes needed for local dev.
# For production deployment use .env.prod.example instead.
# =============================================================================


# =============================================================================
# SesameFS API Server
# =============================================================================

# Internal port inside the container
PORT=8080

# Host port exposed on your machine → http://localhost:3000
SESAMEFS_HOST_PORT=3000

# Public URL used for generating download/upload links.
# Leave commented to derive from the incoming request Host header —
# allows the same container to serve multiple hostnames.
# SERVER_URL=http://localhost:3000


# =============================================================================
# Authentication — dev mode uses static tokens, no OIDC needed
# =============================================================================

AUTH_DEV_MODE=true
AUTH_ALLOW_ANONYMOUS=true

# Dev tokens are defined in config.docker.yaml:
#   dev-token-superadmin  → superadmin role
#   dev-token-admin       → admin role
#   dev-token-user        → user role
#   dev-token-readonly    → readonly role
#   dev-token-guest       → guest role
#
# Usage: curl -H "Authorization: Token dev-token-admin" http://localhost:3000/api2/repos/


# =============================================================================
# OIDC — disabled in dev by default
# =============================================================================
# Uncomment and fill in to test OIDC locally against a real provider.

# OIDC_ENABLED=true
# OIDC_ISSUER=https://accounts.sesamedisk.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URIS=http://localhost:3000/sso
# OIDC_JWT_SIGNING_KEY=
# OIDC_SESSION_TTL=24h             # Web browser sessions
# OIDC_API_TOKEN_TTL=4320h         # Desktop/mobile sync client tokens (180 days)


# =============================================================================
# Cassandra
# =============================================================================

CASSANDRA_HOSTS=cassandra:9042
CASSANDRA_KEYSPACE=sesamefs
CASSANDRA_LOCAL_DC=datacenter1
CASSANDRA_CLUSTER_NAME=sesamefs
CASSANDRA_DC=datacenter1
CASSANDRA_MAX_HEAP_SIZE=512M
CASSANDRA_HEAP_NEWSIZE=100M

# Exposed on host for direct access with cqlsh or DB tools
CASSANDRA_HOST_PORT=9042


# =============================================================================
# S3 — uses local MinIO in dev (S3-compatible, no AWS account needed)
# =============================================================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=sesamefs-blocks
S3_ENDPOINT=http://minio:9000

# MinIO console → http://localhost:9001 (login: minioadmin / minioadmin)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001


# =============================================================================
# Share Link Security
# =============================================================================
# HMAC key used to sign password-unlock cookies for password-protected share
# and upload links. Keeps the user authenticated to the share link for 24 hours
# so they don't have to re-enter the password on every page.
#
# In production this MUST be a securely generated secret (openssl rand -hex 32).
# sesamefs will REFUSE to start in production with this value or if empty.
# In dev mode any value is accepted.
SHARE_LINK_HMAC_KEY=dev-share-link-hmac-key


# =============================================================================
# OnlyOffice Document Server
# =============================================================================

ONLYOFFICE_JWT_SECRET=dev-only-jwt-secret
ONLYOFFICE_HOST_PORT=8088


# =============================================================================
# Seafile CLI — sync protocol testing  [optional, needs --profile debug]
# =============================================================================
# docker compose --profile debug up seafile-cli

SEAF_CLI_SERVER_URL=http://sesamefs:8080
SEAF_CLI_USERNAME=00000000-0000-0000-0000-000000000001
SEAF_CLI_PASSWORD=dev-token-user

# Protocol capture against a real Seafile server  [optional]
# SEAF_DEBUG_SERVER_URL=https://your-seafile-server.com
# SEAF_DEBUG_USERNAME=your-email@example.com
# SEAF_DEBUG_PASSWORD=your-password


# =============================================================================
# File Preview Limits  [optional — defaults in config.docker.yaml are fine]
# =============================================================================
# FILEVIEW_MAX_PREVIEW_BYTES=1073741824    # 1 GB
# FILEVIEW_MAX_VIDEO_BYTES=10737418240     # 10 GB
# FILEVIEW_MAX_TEXT_BYTES=52428800         # 50 MB
# FILEVIEW_MAX_IWORK_PREVIEW_BYTES=52428800 # 50 MB


# =============================================================================
# Frontend Build  [rarely needed]
# =============================================================================
# Empty = relative URLs — API and frontend on same origin (recommended).
# Only set if frontend and backend run on different hosts.
SESAMEFS_API_URL=
