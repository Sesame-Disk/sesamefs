---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="SesameFS">
  <script>
    import { getAuthToken } from '../lib/api';

    const token = getAuthToken();
    if (token) {
      window.location.href = '/libraries/';
    } else {
      window.location.href = '/login/';
    }
  </script>
</AppLayout>
