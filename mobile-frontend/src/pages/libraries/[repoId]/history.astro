---
import AuthenticatedLayout from '../../../layouts/AuthenticatedLayout.astro';
import FileHistory from '../../../components/pages/FileHistory';

export function getStaticPaths() {
  return [];
}

const { repoId } = Astro.params;
const path = Astro.url.searchParams.get('path') || '/';
const fileName = Astro.url.searchParams.get('fileName') || path.split('/').pop() || 'File';
---

<AuthenticatedLayout title="File History" pageTitle="File History">
  <FileHistory client:load repoId={repoId!} path={path} fileName={fileName} />
</AuthenticatedLayout>
