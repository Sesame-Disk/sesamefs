---
import AppLayout from './AppLayout.astro';
import TopBar from '../components/navigation/TopBar';
import BottomNav from '../components/navigation/BottomNav';

interface Props {
  title?: string;
  pageTitle?: string;
}

const { title = 'SesameFS', pageTitle = 'SesameFS' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<AppLayout title={title}>
  <body class="flex flex-col min-h-screen bg-[#f5f5f5]">
    <TopBar title={pageTitle} client:load />
    <main class="flex-1 pt-14 pb-16">
      <slot />
    </main>
    <BottomNav currentPath={currentPath} client:load />
  </body>
  <script>
    import { getAuthToken } from '../lib/api';

    const devBypass = !window.app?.config?.serviceURL;
    const token = getAuthToken();

    if (!token && !devBypass) {
      window.location.href = '/login/';
    }
  </script>
</AppLayout>
