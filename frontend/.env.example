# SesameFS Frontend Configuration
# Copy this file to .env and adjust values for your environment.
#
# For Docker deployments, these values are also set via docker-compose.yaml
# build args and the docker-entrypoint.sh runtime injection.

# =============================================================================
# Build Configuration
# =============================================================================

# Maximum Node.js heap size (in MB) for webpack build.
# Increase if builds fail with "JavaScript heap out of memory".
NODE_MAX_MEMORY=4096

# Generate source maps in production build.
# Set to "true" for debugging, "false" for smaller bundles.
GENERATE_SOURCEMAP=false

# Enable parallel webpack compilation (faster builds, more memory).
WEBPACK_PARALLEL_BUILD=false

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL. Controls where the frontend sends API requests.
#
# - Empty string (default): Uses window.location.origin (same-host deployment).
#   This is the recommended setting for production with nginx proxy.
#
# - Explicit URL: Use when frontend and backend are on different hosts/ports.
#   Example: SESAMEFS_API_URL=http://localhost:8082
#
# For Docker deployments, this can also be set at runtime via the
# SESAMEFS_API_URL environment variable in docker-compose.yaml.
SESAMEFS_API_URL=

# =============================================================================
# Development Settings
# =============================================================================

# Bypass login screen and use dev-token-admin for authentication.
# Set to "true" for local development, remove or set to "false" for production.
REACT_APP_BYPASS_LOGIN=true

# Dev server port (only used with npm start, not Docker).
# PORT=3000

# Dev server bind address.
# HOST=0.0.0.0

# Enable HTTPS for dev server (requires certs).
# HTTPS=true
