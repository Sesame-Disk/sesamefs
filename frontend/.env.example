# SesameFS Frontend Configuration
# Copy this file to .env and modify as needed

# API URL - the SesameFS backend server
# Leave empty for same-origin (when frontend is served by SesameFS)
# Or set to full URL for separate deployment
SESAMEFS_API_URL=http://localhost:8080

# Site configuration (optional - defaults in public/index.html)
# SITE_TITLE=SesameFS
# SITE_NAME=SesameFS

# Development server port
PORT=3000

# Build Optimization Settings
# Set to 'false' to disable parallel processing (reduces memory usage in Docker)
# Parallel builds are faster but use more memory
WEBPACK_PARALLEL_BUILD=false

# Set to 'false' to disable source maps (saves memory during build)
# Source maps are useful for debugging but increase build time and memory
GENERATE_SOURCEMAP=false

# Node.js memory limit for build (in MB)
# Default: 4096 (4GB). Increase if build still fails, decrease to save memory.
NODE_MAX_MEMORY=4096
