# Frontend Build Configuration
# Copy this file to .env and customize as needed

# Node.js memory limit for build (in MB)
# Increase if you get "JavaScript heap out of memory" errors
NODE_MAX_MEMORY=4096

# Generate source maps (set to true for debugging)
GENERATE_SOURCEMAP=false

# Enable parallel webpack builds (faster builds, uses more memory)
WEBPACK_PARALLEL_BUILD=true

# API URL (leave empty for relative URLs / same-origin)
# For development: http://localhost:8080
# For production: leave empty or set to your API domain
SESAMEFS_API_URL=

# Login bypass for testing - skips login page and uses dev-token-admin
# Set to 'true' for development/testing, remove for production
# Requires backend AUTH_ALLOW_ANONYMOUS=true and AUTH_DEV_MODE=true
REACT_APP_BYPASS_LOGIN=false
